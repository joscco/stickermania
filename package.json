{
  "name": "birthday-sandbox-grid",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:back": "npm run build -w @birthday/shared && npm run dev -w @birthday/backend",
    "dev:front": "npm run dev -w @birthday/frontend",
    "build": "npm run build --workspaces --if-present",
    "start": "node apps/backend/dist/index.js --serve-static",
    "lint": "npm run lint --workspaces --if-present"
  },
  "dependencies": {
    "ws": "^8.19.0"
  }
}
