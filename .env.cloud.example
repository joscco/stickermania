# Copy to .env.cloud or export these variables in your shell before using
# npm run cloud:deploy, npm run cloud:start, npm run cloud:stop or
# npm run cloud:destroy-project.

GCP_PROJECT=your-google-cloud-project-id
CLOUD_REGION=europe-west1
CLOUD_RUN_SERVICE=stickermania
ARTIFACT_REPOSITORY=stickermania
CLOUD_ASSET_BUCKET=your-google-cloud-project-id-stickermania-assets

# Required for cloud:deploy and cloud:start unless you intentionally set
# ALLOW_EMPTY_ADMIN_PASSWORD=1 for an open test deployment.
ADMIN_PASSWORD=replace-with-a-long-random-password

CLOUD_RUN_MAX_INSTANCES=1
CLOUD_RUN_CONCURRENCY=200
CLOUD_RUN_CPU=2
CLOUD_RUN_MEMORY=2Gi
