{
  "name": "@stickermania/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./stickermaniaConfig": {
      "types": "./dist/stickermaniaConfig.d.ts",
      "default": "./dist/stickermaniaConfig.js"
    },
    "./defaultStickerCatalogData": {
      "types": "./dist/defaultStickerCatalogData.d.ts",
      "default": "./dist/defaultStickerCatalogData.js"
    },
    "./sessionState": {
      "types": "./dist/sessionState.d.ts",
      "default": "./dist/sessionState.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json -w",
    "lint": "node -e \"console.log('no lint configured')\""
  }
}
