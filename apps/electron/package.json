{
  "name": "@birthday/electron",
  "version": "0.1.0",
  "description": "Desktop host shell for Stickermania LAN games.",
  "author": "Stickermania",
  "private": true,
  "type": "module",
  "main": "main.js",
  "scripts": {
    "icon": "node scripts/build-icon.mjs",
    "prepack": "npm run icon",
    "predist": "npm run icon",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@birthday/shared": "0.1.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.8.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "39.8.10",
    "electron-builder": "26.15.3",
    "png2icons": "^2.0.1"
  },
  "build": {
    "appId": "de.stickermania.host",
    "productName": "Stickermania",
    "icon": "build/icon.png",
    "asar": true,
    "files": [
      "main.js",
      "package.json",
      {
        "from": "../backend/dist",
        "to": "backend"
      },
      {
        "from": "../../packages/shared/dist",
        "to": "node_modules/@birthday/shared/dist"
      },
      {
        "from": "../../packages/shared/package.json",
        "to": "node_modules/@birthday/shared/package.json"
      }
    ],
    "extraResources": [
      {
        "from": "../frontend/dist/frontend/browser",
        "to": "frontend",
        "filter": [
          "**/*",
          "!**/*.psd"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "entitlements": "signing/entitlements.mac.plist",
      "entitlementsInherit": "signing/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "background": "assets/dmg-background.png",
      "iconSize": 96,
      "window": {
        "width": 560,
        "height": 380
      },
      "contents": [
        {
          "x": 165,
          "y": 190,
          "type": "file"
        },
        {
          "x": 395,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Game"
    }
  }
}
